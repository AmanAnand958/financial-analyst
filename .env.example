# ============================================================
# Environment Variables — FDI System
# Copy to .env and fill in your values. NEVER commit .env to Git.
# ============================================================

# ---- LLM Provider ----
# Option A: Groq (recommended for development — free, fast)
# Get key at https://console.groq.com
GROQ_API_KEY="your_groq_api_key_here"

# Option B: Azure OpenAI (recommended for production)
AZURE_OPENAI_API_KEY="your_azure_openai_key_here"
AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com/"
AZURE_OPENAI_DEPLOYMENT_NAME="gpt-35-turbo"

# ---- OpenAI (used by RAGAs evaluation framework) ----
OPENAI_API_KEY="your_openai_key_here"

# ---- Application Settings ----
DEBUG=True
LOG_LEVEL=INFO

# ---- Vector Store ----
CHROMA_DB_PATH="./chroma_db"

# ---- Azure (for deployment) ----
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_CONTAINER_NAME="fdi-documents"
